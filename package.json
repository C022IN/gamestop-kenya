{
  "name": "gamestop-kenya",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "dev:turbo": "next dev -H 0.0.0.0 --turbopack",
    "build": "next build",
    "start": "next start",
    "clean": "node -e \"const fs=require('fs');['.next','.next-dev','tsconfig.tsbuildinfo'].forEach((target)=>fs.rmSync(target,{ recursive:true, force:true }))\"",
    "typecheck": "tsc --noEmit",
    "lint:eslint": "node ./node_modules/eslint/bin/eslint.js src scripts next.config.mjs tailwind.config.ts eslint.config.mjs postcss.config.mjs --no-error-on-unmatched-pattern",
    "lint": "npm run typecheck && npm run lint:eslint",
    "format": "biome format --write",
    "env:audit": "node scripts/vercel-env.mjs --audit",
    "env:example:check": "node scripts/vercel-env.mjs --check-example"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.106.1",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hls.js": "^1.6.16",
    "lucide-react": "^0.577.0",
    "next": "15.5.18",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.15.21",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.18",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
