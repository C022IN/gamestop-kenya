{
  "name": "gamestop-movies-tv",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "prebuild": "expo prebuild --platform android",
    "build:preview": "eas build --platform android --profile preview --non-interactive",
    "build:production": "eas build --platform android --profile production --non-interactive",
    "eas:submit": "eas submit --platform android --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-tvos/config-tv": "^0.1.6",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.0",
    "expo": "~55.0.23",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~55.0.13",
    "expo-image": "~55.0.10",
    "expo-linear-gradient": "~55.0.13",
    "expo-splash-screen": "~55.0.20",
    "expo-status-bar": "~55.0.6",
    "expo-video": "~3.0.0",
    "react": "19.2.6",
    "react-native": "npm:react-native-tvos@0.83.6-0",
    "react-native-reanimated": "~3.17.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.0",
    "react-native-webview": "13.16.1"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av"
        ]
      }
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/react": "~19.2.14",
    "babel-plugin-module-resolver": "^5.0.3",
    "typescript": "~5.9.3"
  }
}
